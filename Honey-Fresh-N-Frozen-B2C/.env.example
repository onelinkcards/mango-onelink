# ---------------------------------------------------------------------------
# Mango – Environment variables (copy to .env.local for local dev)
# For production (Vercel etc.): add these in Project → Settings → Environment Variables
# ---------------------------------------------------------------------------

# Required for Google Reviews (home + /reviews)
# Get key: https://console.cloud.google.com/ → Enable "Places API" → Credentials → Create API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional – admin panel URL for dynamic config (defaults to http://localhost:3002 if unset)
# NEXT_PUBLIC_ADMIN_PANEL_URL=https://your-admin.example.com
